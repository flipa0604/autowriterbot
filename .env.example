# ============================================
# Telegram API (userbot uchun)
# ============================================
# https://my.telegram.org/auth → API development tools → New app
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Userbot login qilinadigan telefon raqami (xalqaro format)
PHONE=+998901234567

# ============================================
# Admin bot (BotFather'dan)
# ============================================
# @BotFather → /newbot → token oling
ADMIN_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Admin'ning Telegram ID'si (faqat shu odam botga komanda yubora oladi)
# @userinfobot ga /start yuborib oling
ADMIN_TELEGRAM_ID=123456789

# ============================================
# Boshqa sozlamalar
# ============================================
# Vaqt zonasi (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=Asia/Tashkent
